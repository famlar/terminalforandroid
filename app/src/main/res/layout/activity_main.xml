<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- 连接控制面板（可折叠） -->
    <LinearLayout
        android:id="@+id/connectionPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- 快速连接栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <EditText
                android:id="@+id/hostInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:layout_marginEnd="3dp"
                android:background="#162447"
                android:gravity="center_vertical"
                android:hint="host"
                android:paddingHorizontal="6dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/portInput"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="3dp"
                android:background="#162447"
                android:gravity="center"
                android:hint="22"
                android:inputType="number"
                android:padding="2dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/userInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:background="#162447"
                android:gravity="center_vertical"
                android:hint="user"
                android:paddingHorizontal="6dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:background="#162447"
                android:gravity="center_vertical"
                android:hint="pass"
                android:inputType="textPassword"
                android:paddingHorizontal="6dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:textSize="12sp" />

            <Button
                android:id="@+id/connectButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:backgroundTint="#00D2FF"
                android:paddingHorizontal="10dp"
                android:text="Connect"
                android:textColor="#0D0D1A"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 状态栏 -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="6dp"
            android:text="Disconnected"
            android:textColor="#666666"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- 终端区域 — 全屏终端，自带键盘输入 -->
    <com.sshterminal.TerminalView
        android:id="@+id/terminalView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D0D1A" />

</LinearLayout>
