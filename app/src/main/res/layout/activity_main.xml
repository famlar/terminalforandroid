<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- 连接控制面板 -->
    <LinearLayout
        android:id="@+id/connectionPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <EditText
            android:id="@+id/hostInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="#162447"
            android:gravity="center_vertical"
            android:hint="host"
            android:paddingHorizontal="8dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/portInput"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:background="#162447"
            android:gravity="center"
            android:hint="22"
            android:inputType="number"
            android:paddingHorizontal="4dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/userInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="#162447"
            android:gravity="center_vertical"
            android:hint="username"
            android:paddingHorizontal="8dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="#162447"
            android:gravity="center_vertical"
            android:hint="password"
            android:inputType="textPassword"
            android:paddingHorizontal="8dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="13sp" />

        <Button
            android:id="@+id/connectButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="#00D2FF"
            android:paddingHorizontal="12dp"
            android:text="Connect"
            android:textColor="#0D0D1A"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 终端输出区域 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbarStyle="insideOverlay"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/terminalOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0D0D1A"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="8dp"
            android:textColor="#00FF88"
            android:textSize="12sp"
            android:typeface="monospace" />
    </ScrollView>

    <!-- 输入栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:orientation="horizontal"
        android:padding="4dp">

        <EditText
            android:id="@+id/commandInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="#162447"
            android:hint="输入命令..."
            android:paddingHorizontal="8dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="13sp" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="#00D2FF"
            android:text="Send"
            android:textColor="#0D0D1A"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
